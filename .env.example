# Copy to .env.local and fill in. NEXT_PUBLIC_* are BAKED INTO THE BUILD,
# so set them BEFORE `npm run build`. .env.local is gitignored.

# Oddvice Go API base URL.
NEXT_PUBLIC_API_URL=https://api.oddvice.app

# Supabase (anon key is public-by-design, protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
